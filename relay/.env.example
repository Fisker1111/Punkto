# punkto-relay v0.1 — environment template
# Copy to /etc/punkto-relay/relay.env on production hosts.
#
# All values shown are the built-in defaults. Uncomment and edit to override.

# --- network ---
#PUNKTO_HOST=127.0.0.1
#PUNKTO_PORT=8000

# --- identity ---
# Returned in /info and /latest. Pick something distinctive per host.
#PUNKTO_NODE_NAME=relay-app1.example.com

# --- storage ---
# Relative paths are resolved from the working directory. For production use
# an absolute path under the relay user's home or /var/lib.
#PUNKTO_DATA_DIR=/var/lib/punkto-relay/data/

# --- buffer limits ---
# Hard cap on atoms in memory and on disk. Oldest are pruned when exceeded.
#PUNKTO_BUFFER_ATOMS=10000
# Atoms older than this many hours are pruned even if under the count cap.
#PUNKTO_BUFFER_HOURS=168

# --- /latest tuning ---
# Maximum atoms returned by GET /latest in a single response.
#PUNKTO_LATEST_LIMIT=100

# --- peer mesh ---
# Comma-separated list of peer relay base URLs. Each is polled every
# PUNKTO_SYNC_INTERVAL seconds via /latest (falling back to /feed).
# Example for a two-node mesh:
#PUNKTO_PEERS=https://app2.example.com,https://app3.example.com
#PUNKTO_SYNC_INTERVAL=30
