# ── Punkto Node — environment configuration ──────────────────────────────────
# Copy this file to .env and edit for your node.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   nano .env
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# Docker image version to run.
# Use a specific version tag (e.g. v0.45) for production stability.
# Use 'latest' to always pull the newest build.
PUNKTO_VERSION=latest

# Human-readable name for this relay node (shown in /info)
PUNKTO_NODE_NAME=node1

# Comma-separated list of peer relay URLs to sync atoms with.
# Leave empty for a standalone node.
# Example: PUNKTO_PEERS=https://node2.example.com,https://node3.example.com
PUNKTO_PEERS=

# Maximum number of atoms to keep in the rolling buffer
PUNKTO_BUFFER_ATOMS=10000

# Maximum age of atoms in hours before they are rotated out
PUNKTO_BUFFER_HOURS=168

# Peer sync interval in seconds
PUNKTO_SYNC_INTERVAL=30
