# app2.punkto.xyz — Punkto node 2
# Caddy auto-HTTPS via Let's Encrypt

app2.punkto.xyz {
    root * /srv
    file_server

    @relay_paths path /atom /atom/* /latest /stream /feed /health /info \
        /llms.txt /robots.txt /sitemap.xml /openapi.json \
        /punkto.ai.md /punkto.md /punkto.node.md /punkto.sync.md \
        /punkto.manifest.md /punkto.identity.md /punkto.ui.md \
        /.well-known/*
    reverse_proxy @relay_paths relay:8000

    @relay_patterns path_regexp relay ^/(punkto(/.*)?|p/.+)$
    reverse_proxy @relay_patterns relay:8000

    @is_relay {
        path /atom /atom/* /latest /stream /feed /health /info
        path /punkto* /p/*
    }
    header @is_relay Access-Control-Allow-Origin "*"
    header @is_relay Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header @is_relay Access-Control-Allow-Headers "Content-Type, Authorization"

    @sw path /sw.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"
    header @sw Pragma "no-cache"
    header @sw Expires "0"

    @app {
        not path /lib/*
        path *.html *.js
    }
    header @app Cache-Control "no-cache, no-store, must-revalidate"
    header @app Pragma "no-cache"
    header @app Expires "0"

    @static_libs path /lib/*
    header @static_libs Cache-Control "public, max-age=86400, immutable"

    header {
        X-Content-Type-Options  nosniff
        X-Frame-Options         DENY
        Referrer-Policy         strict-origin-when-cross-origin
        -Server
    }

    encode gzip

    log {
        output stderr
        format console
        level INFO
    }
}
