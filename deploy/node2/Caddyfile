# ── node2 Caddyfile ───────────────────────────────────────────────────────────
# Domain: app1.punkto.xyz  (rename to node2.punkto.xyz when DNS is ready)
# This file is mounted into the web container at /etc/caddy/Caddyfile
# Edit the domain below if the node's domain changes.
# ─────────────────────────────────────────────────────────────────────────────

app1.punkto.xyz {

    # Serve static PWA files from /srv
    root * /srv
    file_server

    # Proxy relay API endpoints to the relay container
    reverse_proxy /atom*    relay:8000
    reverse_proxy /feed*    relay:8000
    reverse_proxy /latest*  relay:8000
    reverse_proxy /health*  relay:8000
    reverse_proxy /info*    relay:8000
    reverse_proxy /p/*      relay:8000

    # Security headers
    header {
        X-Content-Type-Options  nosniff
        X-Frame-Options         DENY
        Referrer-Policy         strict-origin-when-cross-origin
        -Server
    }

    # Cache static library assets for 1 day
    @static_libs {
        path /lib/*
        path *.png *.ico *.webmanifest
    }
    header @static_libs Cache-Control "public, max-age=86400, immutable"

    # Never cache SW and app.js — client must always get the latest version
    @no_cache {
        path /sw.js
        path /app.js
        path /index.html
    }
    header @no_cache Cache-Control "no-cache, no-store, must-revalidate"

    # Logging
    log {
        output stderr
        format console
        level INFO
    }
}
