<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    cloud-backup: allowlist mode — only database is backed up to cloud.
    device-transfer: include database + sync prefs for device migration.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="punkto.db" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="punkto.db" />
        <include domain="sharedpref" path="punkto_sync.xml" />
    </device-transfer>
</data-extraction-rules>
