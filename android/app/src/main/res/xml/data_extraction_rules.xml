<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Android 12+ (API 31+).
   Controls what is included in cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="punkto.db" />
        <exclude domain="sharedpref" path="punkto_sync.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="punkto.db" />
        <include domain="sharedpref" path="punkto_sync.xml" />
    </device-transfer>
</data-extraction-rules>
